# --- Video pipeline (critical path) ---
FAL_KEY=                       # fal.ai — Seedream/FLUX keyframes + Wan 2.6 Flash / Kling / LTX-2 video

# --- LLM creative director (priority: Anthropic -> TrueFoundry -> Bedrock) ---
ANTHROPIC_API_KEY=             # Fable 5 director — Anthropic is a sponsor; preferred path
ANTHROPIC_MODEL=claude-fable-5
TRUEFOUNDRY_API_KEY=           # gateway fronting LLM calls (per-skill virtual tokens)
TRUEFOUNDRY_BASE_URL=https://gateway.truefoundry.ai
AWS_PROFILE=                   # Bedrock fallback only
AWS_REGION=us-west-2

# --- Sponsor skills ---
JUA_API_KEY=                   # "ID:SECRET" from developer.jua.ai — weather-promo skill
PIONEER_API_KEY=               # pioneer.ai — copywriter adaptive inference
PIONEER_MODEL=qwen3-8b

# --- Publishing ---
SENSO_API_KEY=                 # tgr_... from senso.ai/api-keys (cited.md publishing)

# --- Payments (Emanuele) ---
MPP_SECRET_KEY=                # root-of-trust, never commit
MPP_NETWORK=testnet

# --- Telemetry / leaderboard ---
CLICKHOUSE_URL=
CLICKHOUSE_PASSWORD=

# --- Distribution / finale ---
COMPOSIO_API_KEY=              # auto-post finished video to Slack/X
RENDER_API_KEY=                # deploys

# --- Storage ---
S3_BUCKET=                     # rendered video delivery (presigned URLs)

# Composio
COMPOSIO_USER_ID=agent-app-store
COMPOSIO_SLACK_CHANNEL=#general

# Runware (alternative render provider to fal)
RUNWARE_API_KEY=
RUNWARE_VIDEO_MODEL=          # AIR id from runware.ai/models, e.g. a Kling/Hailuo i2v model
RUNWARE_IMAGE_MODEL=runware:101@1
VIDEO_PROVIDER=               # force "fal" or "runware"; default = whichever key exists
